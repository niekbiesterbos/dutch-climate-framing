   <text ana="#reference" xml:lang="nl">
      <body>
         <div type="debateSection">
            <head xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.head1">Regeling van werkzaamheden (stemmingen)</head>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.u1">
               <seg xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.seg1">Voordat we gaan stemmen is er nu een korte regeling.</seg>
               <seg xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.seg2">Ik stel voor zo dadelijk ook te stemmen over de aangehouden moties-Ploumen (34170, nrs. 8 en 9).</seg>
            </u>
            <note type="comment" xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.note1">Daartoe wordt besloten.</note>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.u2">
               <seg xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.seg3">Mevrouw Kröger.</seg>
            </u>
            <u who="#SuzanneKröger" ana="#regular topic:trans" xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.u3">
               <seg xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.seg4">Voorzitter. Ik zou graag mijn motie op stuk nr. 677 bij punt 18, de stemmingen over moties ingediend bij het VAO Luchtvaart, aanhouden.</seg>
            </u>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.u4">
               <seg xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.seg5">Op verzoek van mevrouw Kröger stel ik voor haar motie (31936, nr. 677) aan te houden.</seg>
               <seg xml:id="ParlaMint-NL_2019-10-01-tweedekamer-6.seg6">Daartoe wordt besloten.</seg>
            </u>
         </div>
      </body>
   </text>
