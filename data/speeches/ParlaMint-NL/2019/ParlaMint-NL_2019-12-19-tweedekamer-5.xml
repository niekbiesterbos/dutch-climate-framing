   <text ana="#reference" xml:lang="nl">
      <body>
         <div type="debateSection">
            <head xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.head1">Regeling van werkzaamheden (stemmingen)</head>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.u1">
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg1">Ik stel voor zo dadelijk ook te stemmen over de volgende aangehouden moties:</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg2">de motie-Verhoeven (35300-XIII, nr. 58),</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg3">de motie-Groothuizen/Den Boer (34641, nr. 16);</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg4">de motie-Den Boer/Özütok (35300-VII, nr. 28);</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg5">de motie-Den Boer (35165, nr. 14);</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg6">de motie-Van der Graaf c.s. (24557, nr. 161);</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg7">de motie-Van der Linde (31477, nr. 45);</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg8">de motie-Ouwehand c.s. (35300-XVII, nr. 43).</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg9">Aan de orde zijn de stemmingen.</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg10">O, mevrouw Van Kooten-Arissen, ik was u bijna vergeten.</seg>
            </u>
            <u who="#FemkeMerelvanKooten-Arissen" ana="#regular topic:immig" xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.u2">
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg11">Voorzitter, dat geeft niet, dank u wel. Bij punt 16, Vreemdelingen- en asielbeleid, wil ik graag mijn moties op de stukken nrs. 2557 en 2558 aanhouden.</seg>
            </u>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.u3">
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg12">Op verzoek van mevrouw Van Kooten-Arissen stel ik voor haar moties (19637, nrs. 2557 en 2558) aan te houden.</seg>
               <seg xml:id="ParlaMint-NL_2019-12-19-tweedekamer-5.seg13">Daartoe wordt besloten.</seg>
            </u>
         </div>
      </body>
   </text>
