   <text ana="#reference" xml:lang="nl">
      <body>
         <div type="debateSection">
            <head xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.head1">Regeling van werkzaamheden (stemmingen)</head>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.u1">
               <seg xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.seg1">Ik geef eerst het woord aan de heer Fritsma.</seg>
            </u>
            <u who="#SietseFritsma" ana="#regular topic:immig" xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.u2">
               <seg xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.seg2">Dank, voorzitter. Ik wil graag de motie op stuk nr. 2450 (19637) over het niet ondersteunen van het VN-vluchtelingenpact hoofdelijk in stemming brengen.</seg>
            </u>
            <u who="#KhadijaArib" ana="#chair topic:other" xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.u3">
               <seg xml:id="ParlaMint-NL_2018-12-13-tweedekamer-14.seg3">Dan gaan we dat doen. Dan gaan we eerst hoofdelijk stemmen.</seg>
            </u>
         </div>
      </body>
   </text>
